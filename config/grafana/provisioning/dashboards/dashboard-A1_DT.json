      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "pluginVersion": "13.1.0",
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb_sensors"
          },
          "query": "from(bucket: \"sensors\")\n  |> range(start: -15m)\n  |> filter(fn: (r) => r._measurement == \"lab_twin_state\")\n  |> filter(fn: (r) => r._field == \"temperature\")\n  |> group(columns: [\"_field\"])\n  |> last()\n  |> keep(columns: [\"_time\", \"_value\"])\n  |> rename(columns: {_value: \"temperature\"})",
          "refId": "A"
        }
      ],
      "title": "Current Temperature",
      "type": "stat"
    },
